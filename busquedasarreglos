 class Arreglo {

  // Método para llenar con números aleatorios
  
  public void busquedaLineal2(int valor, int datos[]){
      boolean encontrado=false;
      for (int i=0;i<datos.length; i++)
      {
          if (valor == datos[i]){
              System.out.println("El dato está en la pos : "+i);
              encontrado=true;
          }
      }
      if(!(encontrado))
      System.out.println("El dato no estuvo");
  }
  
  public int busquedaLineal1(int valor, int datos[])
  {
      int posicion = (-1);
      for (int i=0; i<datos.length; i++){
          if (valor == datos [i])
                return i;
      }
      return posicion;
  }

  public void llenarAleatorio(int datos[]) {

    Random random = new Random();

    for (int i = 0; i < datos.length; i++) {

      datos[i] = random.nextInt(30);

    }

  }

  public void imprimir(int datos[]) {

    for (int i = 0; i < datos.length; i++) {

      System.out.print(datos[i]+" ");

    }

  }

}
