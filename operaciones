public class OperacionesMatrices {

    public static void main(String[] args) {
        // Matriz de ejemplo (3x3)
        int[][] miMatriz = {
            { 5, -2,  3},
            { 1,  8, -6},
            {-4,  7,  2}
        };

        // Pruebas de los métodos
        sumar(miMatriz);
        
        int totalNegativos = negativos(miMatriz);
        System.out.println("Cantidad de valores negativos: " + totalNegativos);
        
        int valorTraza = traza(miMatriz);
        System.out.println("La traza de la matriz es: " + valorTraza);
    }

    // 1) Método para sumar todos los elementos e imprimir el resultado
    public static void sumar(int[][] matriz) {
        int sumaTotal = 0;
        for (int i = 0; i < matriz.length; i++) { // Recorre filas
            for (int j = 0; j < matriz[i].length; j++) { // Recorre columnas
                sumaTotal += matriz[i][j];
            }
        }
        System.out.println("La suma de todos los elementos es: " + sumaTotal);
    }

    // 2) Método para contar valores negativos
    public static int negativos(int[][] matriz) {
        int contador = 0;
        for (int[] fila : matriz) {
            for (int elemento : fila) {
                if (elemento < 0) {
                    contador++;
                }
            }
        }
        return contador;
    }

    // 3) Método para calcular la traza (diagonal principal)
    public static int traza(int[][] matriz) {
        int sumaDiagonal = 0;
        // La traza solo se define para matrices cuadradas (n x n)
        // Usamos un solo bucle ya que en la diagonal fila == columna (i, i)
        for (int i = 0; i < matriz.length; i++) {
            sumaDiagonal += matriz[i][i];
        }
        return sumaDiagonal;
    }
}
