public class AnalizadorNotas {

    public static void main(String[] args) {
        // Ejemplo de uso con un arreglo de calificaciones
        int[] misCalificaciones = {8, 5, 10, 3, 7, 6, 4, 9};
        
        mostrarPorcentajeAprobados(misCalificaciones);
    }

   
    public static void mostrarPorcentajeAprobados(int[] notas) {
        if (notas == null || notas.length == 0) {
            System.out.println("El arreglo está vacío.");
            return;
        }

        int aprobados = 0;
        int notaMinima = 6; // Puedes cambiar esto a 5 si es el criterio de tu escuela

        for (int nota : notas) {
            if (nota >= notaMinima) {
                aprobados++;
            }
        }

        // Calculamos el porcentaje
        // Multiplicamos por 100.0 para forzar la división decimal
        double porcentaje = (aprobados * 100.0) / notas.length;

        System.out.println("Total de notas: " + notas.length);
        System.out.println("Notas aprobatorias: " + aprobados);
        System.out.printf("Porcentaje de aprobación: %.2f%%\n", porcentaje);
    }
}
